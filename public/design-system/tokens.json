{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Object Biography design tokens — W3C DTCG format. Compatible with Style Dictionary, Tokens Studio, Figma Tokens.",

  "color": {
    "bg":                  { "$value": "#1B1B17", "$type": "color", "$description": "Near-black background — primary surface" },
    "fg":                  { "$value": "#EDEAE1", "$type": "color", "$description": "Off-white primary text" },
    "fg-dim":              { "$value": "#9C9990", "$type": "color", "$description": "Muted secondary text and labels" },
    "fg-faint":            { "$value": "#5A5750", "$type": "color", "$description": "Tertiary UI — quietest text" },
    "rule":                { "$value": "#3A3A34", "$type": "color", "$description": "Hairline divider on dark background" },
    "surface-raised":      { "$value": "#26261F", "$type": "color", "$description": "Raised panel / tweaks chrome" },

    "paper":               { "$value": "#F8F5EB", "$type": "color", "$description": "Aged paper ground for certificates" },
    "paper-dim":           { "$value": "#E8E4D8", "$type": "color", "$description": "Secondary paper tone" },
    "paper-ink":           { "$value": "#2A2720", "$type": "color", "$description": "Primary ink on paper" },
    "paper-body":          { "$value": "#3D3830", "$type": "color", "$description": "Body text on paper" },
    "paper-meta":          { "$value": "#6A655C", "$type": "color", "$description": "Secondary text on paper" },
    "paper-label":         { "$value": "#7A7469", "$type": "color", "$description": "Eyebrow / metadata label" },
    "paper-faint":         { "$value": "#9A9590", "$type": "color", "$description": "Tertiary text on paper" },
    "paper-rule":          { "$value": "#C8C3B0", "$type": "color", "$description": "Hairline divider on paper" },
    "paper-mark":          { "$value": "#B0AA98", "$type": "color", "$description": "Corner registration mark on paper" },

    "red":                 { "$value": "#C41E1E", "$type": "color", "$description": "DECEASED stamp and failure mark — only signal color" }
  },

  "font": {
    "mono":  { "$value": "'Courier New', 'Courier', monospace", "$type": "fontFamily", "$description": "Primary register — UI, headlines, labels, certificate fields" },
    "serif": { "$value": "'Georgia', 'Times New Roman', serif",  "$type": "fontFamily", "$description": "Editorial register — taglines, argument, second-life quotes" }
  },

  "fontSize": {
    "caption":   { "$value": "9px",   "$type": "dimension" },
    "meta":      { "$value": "10px",  "$type": "dimension" },
    "micro":     { "$value": "11px",  "$type": "dimension" },
    "small":     { "$value": "12px",  "$type": "dimension" },
    "base":      { "$value": "13px",  "$type": "dimension" },
    "button":    { "$value": "11px",  "$type": "dimension" },
    "cert-head": { "$value": "22px",  "$type": "dimension" },
    "h3":        { "$value": "1.4rem", "$type": "dimension" },
    "h2":        { "$value": "clamp(1.4rem, 2.5vw, 2rem)",     "$type": "dimension" },
    "display":   { "$value": "clamp(1.5rem, 3vw, 2.1rem)",     "$type": "dimension" },
    "quote":     { "$value": "clamp(1.15rem, 2.2vw, 1.5rem)",  "$type": "dimension" },
    "hero":      { "$value": "clamp(2.8rem, 5vw, 4.2rem)",     "$type": "dimension" }
  },

  "lineHeight": {
    "tight":   { "$value": 1.1,  "$type": "number" },
    "snug":    { "$value": 1.25, "$type": "number" },
    "normal":  { "$value": 1.5,  "$type": "number" },
    "relaxed": { "$value": 1.6,  "$type": "number" },
    "loose":   { "$value": 1.75, "$type": "number" }
  },

  "letterSpacing": {
    "tight":     { "$value": "-0.02em", "$type": "dimension" },
    "normal":    { "$value": "0",       "$type": "dimension" },
    "wide":      { "$value": "0.05em",  "$type": "dimension" },
    "wider":     { "$value": "0.1em",   "$type": "dimension" },
    "uppercase": { "$value": "0.15em",  "$type": "dimension" },
    "eyebrow":   { "$value": "0.18em",  "$type": "dimension" },
    "stamp":     { "$value": "0.2em",   "$type": "dimension" },
    "authority": { "$value": "0.22em",  "$type": "dimension" },
    "max":       { "$value": "0.25em",  "$type": "dimension" }
  },

  "fontWeight": {
    "regular": { "$value": 400, "$type": "number" },
    "bold":    { "$value": 700, "$type": "number" }
  },

  "space": {
    "0":  { "$value": "0",        "$type": "dimension" },
    "1":  { "$value": "0.25rem",  "$type": "dimension", "$description": "4px" },
    "2":  { "$value": "0.5rem",   "$type": "dimension", "$description": "8px" },
    "3":  { "$value": "0.75rem",  "$type": "dimension", "$description": "12px" },
    "4":  { "$value": "1rem",     "$type": "dimension", "$description": "16px" },
    "5":  { "$value": "1.25rem",  "$type": "dimension", "$description": "20px" },
    "6":  { "$value": "1.5rem",   "$type": "dimension", "$description": "24px" },
    "8":  { "$value": "2rem",     "$type": "dimension", "$description": "32px" },
    "10": { "$value": "2.5rem",   "$type": "dimension", "$description": "40px" },
    "12": { "$value": "3rem",     "$type": "dimension", "$description": "48px" },
    "16": { "$value": "4rem",     "$type": "dimension", "$description": "64px" },
    "20": { "$value": "5rem",     "$type": "dimension", "$description": "80px" },
    "24": { "$value": "6rem",     "$type": "dimension", "$description": "96px" },
    "28": { "$value": "7rem",     "$type": "dimension", "$description": "112px — default section padding" },
    "32": { "$value": "8rem",     "$type": "dimension", "$description": "128px" }
  },

  "container": {
    "default": { "$value": "1080px", "$type": "dimension" },
    "wide":    { "$value": "1280px", "$type": "dimension" },
    "narrow":  { "$value": "680px",  "$type": "dimension" },
    "cta":     { "$value": "600px",  "$type": "dimension" }
  },

  "border": {
    "hairline":   { "$value": "1px solid #3A3A34", "$type": "border" },
    "paper":      { "$value": "1px solid #C8C3B0", "$type": "border" },
    "double":     { "$value": "3px double #3A3A34", "$type": "border" },
    "strong":     { "$value": "2px solid #2A2720", "$type": "border" }
  },

  "radius": {
    "none": { "$value": "0", "$type": "dimension", "$description": "Archival aesthetic — never use rounded corners" }
  },

  "shadow": {
    "paper": {
      "$value": "0 0 0 1px #C8C3B0, 0 4px 24px rgba(0,0,0,0.35), 0 1px 0 #E2DDCE inset",
      "$type": "shadow",
      "$description": "Layered shadow that produces aged-paper edge for certificates"
    },
    "paper-stack": {
      "$value": "0 2px 12px rgba(0,0,0,0.25)",
      "$type": "shadow",
      "$description": "Lighter shadow for stacked certificate thumbnails"
    }
  },

  "duration": {
    "fast": { "$value": "0.15s", "$type": "duration" }
  }
}
